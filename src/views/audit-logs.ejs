<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %></title>
    <link rel="stylesheet" href="/css/style.css" />
  </head>
  <body>
    <main class="page-shell">
      <section class="hero-card dashboard-card">
        <div class="dashboard-header">
          <div>
            <p class="eyebrow">MiniCart Admin</p>
            <h1>Audit Logs</h1>
            <p>Newest activity first across seeded and live product actions.</p>
          </div>
          <a class="secondary-button secondary-button--link" href="/admin">Back to dashboard</a>
        </div>

        <ul class="activity-list">
          <% auditLogs.forEach((entry) => { %>
            <li>
              <strong><%= entry.username %></strong>
              <span><%= entry.action %></span>
              <small><%= entry.entityType %>#<%= entry.entityId %></small>
            </li>
          <% }) %>
        </ul>
      </section>
    </main>
  </body>
</html>
